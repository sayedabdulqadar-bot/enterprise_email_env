ARG BASE_IMAGE=ghcr.io/meta-pytorch/openenv-base:latest
FROM ${BASE_IMAGE}

WORKDIR /app

# Install system deps
RUN apt-get update && \
    apt-get install -y --no-install-recommends git curl && \
    rm -rf /var/lib/apt/lists/*

# Copy project
COPY . /app

# Install Python dependencies (SAFE METHOD)
RUN pip install --no-cache-dir fastapi uvicorn pydantic

# Set Python path
ENV PYTHONPATH="/app"

# Start server
CMD ["sh", "-c", "cd /app && uvicorn env.server.app:app --host 0.0.0.0 --port ${PORT:-7860}"]